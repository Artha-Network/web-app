# Web App Environment Variables
# Copy to .env and fill in values

# Required. Actions server URL (empty in production = same-origin proxy via Vercel rewrites)
VITE_ACTIONS_SERVER_URL=http://localhost:4000

# Required. Solana RPC endpoint
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Required. Solana cluster ('devnet' or 'mainnet-beta')
VITE_SOLANA_CLUSTER=devnet

# Required. USDC mint address (must match actions-server USDC_MINT)
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Required. Anchor program ID (must match actions-server PROGRAM_ID)
VITE_PROGRAM_ID=B1a1oejNg8uWz7USuuFSqmRQRUSZ95kk2e4PzRZ7Uti4

# Optional. Supabase (for real-time subscriptions)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
